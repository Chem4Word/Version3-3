<UserControl
    x:Class="Chem4Word.ACME.Controls.ElectronsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:acme="clr-namespace:Chem4Word.ACME"
    xmlns:controls="clr-namespace:Chem4Word.ACME.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid d:IsLocked="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="154" />
        </Grid.RowDefinitions>

        <ToggleButton
            x:Name="ElectronsModeSwitch"
            Grid.Row="0"
            Height="32"
            Margin="2,0,2,5"
            d:IsLocked="True"
            Checked="OnSwitchToAutomatic"
            Content="Switch to ..."
            IsChecked="False"
            Unchecked="OnSwitchToManual" />

        <controls:Compass
            x:Name="ManualElectrons"
            Grid.Row="1"
            d:IsLocked="True"
            x:FieldModifier="public"
            CompassControlType="Electrons"
            ValueChanged="OnValueChanged_ManualElectrons"
            Visibility="Visible" />

        <controls:AutoElectronsControl
            x:Name="AutomaticElectrons"
            Grid.Row="1"
            Width="154"
            d:IsLocked="True"
            x:FieldModifier="public"
            ValueChanged="OnValueChanged_AutomaticElectrons"
            Visibility="Collapsed" />

    </Grid>
</UserControl>
