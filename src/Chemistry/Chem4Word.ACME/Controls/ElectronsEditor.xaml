<UserControl
    x:Class="Chem4Word.ACME.Controls.ElectronsEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Chem4Word.ACME.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="clr-namespace:Chem4Word.Model2.Enums;assembly=Chem4Word.Model2"
    xmlns:local="clr-namespace:Chem4Word.ACME.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="154"
    d:DesignWidth="154"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Chem4Word.ACME;component/Resources/ControlStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Chem4Word.ACME;component/Resources/Brushes.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:ElectronTypeEnumToDescription x:Key="EnumDescriptionConverter" />

            <ObjectDataProvider
                x:Key="ElectronTypes"
                MethodName="GetValues"
                ObjectType="{x:Type enums:ElectronType}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="enums:ElectronType" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid d:IsLocked="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer
            x:Name="ScrollViewer"
            Grid.Row="0"
            Padding="0"
            d:IsLocked="True"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl
                d:IsLocked="True"
                Grid.IsSharedSizeScope="True"
                ItemsSource="{Binding AutomaticElectronItems, Mode=TwoWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="24" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="22" />
                            </Grid.RowDefinitions>

                            <Button
                                x:Name="DeleteRow"
                                Grid.Column="0"
                                Width="12"
                                Height="12"
                                Margin="0,0,5,0"
                                Padding="0"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Click="OnDeleteRowClicked"
                                ToolTip="Delete this item">
                                <Viewbox Stretch="UniformToFill">
                                    <Path
                                        Data="M3,0 C3.8,0,4.5,0.3,5.1,0.9 L16,11.7 26.9,0.9 C28.1,-0.3 30,-0.3 31.1,0.9 32.3,2.1 32.3,4 31.1,5.1 L20.2,16 31.1,26.9 C32.3,28.1 32.3,30 31.1,31.1 29.9,32.3 28,32.3 26.9,31.1 L16,20.2 5.1,31.1 C3.9,32.3 2,32.3 0.9,31.1 -0.3,29.9 -0.3,28 0.9,26.9 L11.8,16 0.9,5.1 C-0.3,3.9 -0.3,2 0.9,0.9 1.5,0.3 2.2,0 3,0z"
                                        Fill="{StaticResource Chem4WordBlue}"
                                        Stretch="Fill" />
                                </Viewbox>
                            </Button>

                            <ComboBox
                                Grid.Column="1"
                                Margin="0,0,3,0"
                                Padding="3"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                ItemsSource="{Binding Source={StaticResource ElectronTypes}}"
                                SelectedItem="{Binding ElectronType, Mode=TwoWay}"
                                SelectionChanged="OnChanged_ElectronTypeCombo">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Button
                                x:Name="Icon"
                                Grid.Column="2"
                                Width="24"
                                Height="24"
                                Margin="0"
                                Padding="0"
                                VerticalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border BorderThickness="0">
                                            <ContentPresenter Content="{Binding DataContext.ButtonContent, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="1" d:IsLocked="True">
            <Grid d:IsLocked="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="Add"
                    Grid.Column="0"
                    Width="Auto"
                    Margin="3,3,0,3"
                    d:IsLocked="True"
                    Click="OnClick_Add">
                    Add
                </Button>
                <ComboBox
                    x:Name="ComboBox"
                    Grid.Column="1"
                    Margin="3"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    d:IsLocked="True"
                    ItemsSource="{Binding Source={StaticResource ElectronTypes}}"
                    SelectionChanged="OnSelectionChanged_ElectronType">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

            </Grid>
        </Grid>
    </Grid>
</UserControl>
