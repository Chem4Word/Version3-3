<Window
    x:Class="Wpf.UI.Sandbox.Forms.CompassTesting"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:acme="clr-namespace:Chem4Word.ACME;assembly=Chem4Word.ACME"
    xmlns:controls="clr-namespace:Chem4Word.ACME.Controls;assembly=Chem4Word.ACME"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:enums="clr-namespace:Chem4Word.Model2.Enums;assembly=Chem4Word.Model2"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="ThisWindow"
    Title="Testing of Compass Control"
    ContentRendered="CompassTesting_OnContentRendered"
    SizeToContent="WidthAndHeight"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="1">
            Atom Mode
        </TextBlock>

        <controls:Compass
            x:Name="CompassControl1"
            Grid.Row="1"
            Grid.Column="1"
            VerticalAlignment="Top"
            CompassControlType="Hydrogens"
            ValueChanged="OnCompassValueChanged_Compass" />

        <TextBlock Grid.Row="0" Grid.Column="3">
            Functional Group Mode
        </TextBlock>

        <TextBlock Grid.Row="0" Grid.Column="5">
            Electrons
        </TextBlock>

        <controls:Compass
            x:Name="CompassControl2"
            Grid.Row="1"
            Grid.Column="3"
            VerticalAlignment="Top"
            CompassControlType="FunctionalGroups"
            ValueChanged="OnCompassValueChanged_Compass" />

        <controls:ElectronsControl
            x:Name="ElectronsControl"
            Grid.Row="1"
            Grid.Column="5"
            VerticalAlignment="Top"
            ValueChanged="OnValueChanged_Electrons" />

        <acme:Display
            x:Name="Display"
            Grid.Row="2"
            Grid.Column="3"
            Width="154"
            Height="154"
            BorderBrush="Gold"
            BorderThickness="3"
            HighlightActive="False" />


    </Grid>
</Window>
